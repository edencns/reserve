<html lang="en" vid="0"><head vid="1">
<meta charset="UTF-8" vid="2">
<meta name="viewport" content="width=device-width, initial-scale=1.0" vid="3">
<title vid="4">Aura Move-in Fairs</title>
<link rel="preconnect" href="https://fonts.googleapis.com" vid="5">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" vid="6">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&amp;family=Playfair+Display:ital,wght@0,400;0,500;1,400&amp;display=swap" rel="stylesheet" vid="7">
<style vid="8">
    :root {
        --brand-lime: #E8EEF4; 
        --brand-dark: #0F1F3D; 
        --brand-accent: #A8C4DC; 
        --brand-white: #ffffff;
        
        --font-serif: 'Playfair Display', serif;
        --font-sans: 'Inter', sans-serif;
        
        --spacing-xs: 0.5rem;
        --spacing-sm: 1rem;
        --spacing-md: 2rem;
        --spacing-lg: 4rem;
        --spacing-xl: 8rem;

        --radius-arch: 500px 500px 0 0;
        --border-thin: 1px solid var(--brand-dark);
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background-color: var(--brand-lime);
        color: var(--brand-dark);
        font-family: var(--font-sans);
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
    }

    h1, h2, h3, .serif-text {
        font-family: var(--font-serif);
        font-weight: 400;
    }

    .display-title {
        font-size: clamp(3rem, 6vw, 6rem);
        line-height: 1.1;
        text-transform: uppercase;
        letter-spacing: -0.02em;
    }

    .section-title {
        font-size: 2.5rem;
        margin-bottom: var(--spacing-md);
    }

    .label-text {
        font-family: var(--font-sans);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        font-weight: 500;
    }

    .body-text {
        font-size: 1rem;
        opacity: 0.8;
    }

    .sparkle {
        display: inline-block;
        font-family: var(--font-sans);
        font-size: 1.5rem;
        line-height: 1;
        margin: 0 var(--spacing-sm);
        vertical-align: middle;
        color: var(--brand-accent);
    }

    .container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 var(--spacing-md);
    }

    header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: var(--spacing-md) 0;
        border-bottom: var(--border-thin);
    }

    nav {
        display: flex;
        gap: var(--spacing-md);
    }

    nav a {
        color: var(--brand-dark);
        text-decoration: none;
    }

    .hero {
        display: grid;
        grid-template-columns: 1fr 1fr;
        min-height: 85vh;
        border-bottom: var(--border-thin);
    }

    .hero-content {
        padding: var(--spacing-xl) var(--spacing-md) var(--spacing-xl) 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .hero-meta {
        display: flex;
        justify-content: space-between;
        margin-bottom: var(--spacing-lg);
    }

    .hero-image-wrapper {
        padding: var(--spacing-lg) 0 0 var(--spacing-lg);
        height: 100%;
        display: flex;
        align-items: flex-end;
    }

    .hero-arch {
        width: 100%;
        height: 90%;
        background-color: var(--brand-dark);
        border-radius: var(--radius-arch);
        overflow: hidden;
        position: relative;
    }

    .hero-arch img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.8;
        filter: grayscale(0.4) brightness(0.9);
    }

    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.8rem 1.5rem;
        background: transparent;
        color: var(--brand-dark);
        border: var(--border-thin);
        cursor: pointer;
        text-transform: uppercase;
        font-family: var(--font-sans);
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        transition: all 0.2s ease;
    }

    .btn:hover {
        background: var(--brand-accent);
        color: var(--brand-dark);
    }

    .btn-solid {
        background: var(--brand-dark);
        color: var(--brand-lime);
    }

    .btn-solid:hover {
        background: var(--brand-accent);
        color: var(--brand-dark);
        border-color: var(--brand-accent);
    }

    .events-section {
        padding: var(--spacing-xl) 0;
    }

    .events-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--spacing-lg);
        margin-top: var(--spacing-lg);
    }

    .event-card {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-md);
    }

    .event-card-img {
        width: 100%;
        aspect-ratio: 3/4;
        border-radius: var(--radius-arch);
        background: var(--brand-dark);
        overflow: hidden;
    }

    .event-card-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.9;
        filter: grayscale(0.3);
    }

    .event-card-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
    }

    .event-title {
        font-size: 1.75rem;
    }

    .info-section {
        background: var(--brand-dark);
        color: var(--brand-lime);
        padding: var(--spacing-xl) 0;
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--spacing-xl);
    }

    .info-block {
        border-top: 1px solid rgba(168, 196, 220, 0.3);
        padding-top: var(--spacing-md);
    }

    .info-number {
        font-family: var(--font-serif);
        font-size: 3rem;
        margin-bottom: var(--spacing-sm);
        display: block;
        color: var(--brand-accent);
    }

    .kiosk-section {
        padding: var(--spacing-xl) 0;
        border-top: var(--border-thin);
    }

    .kiosk-interface {
        max-width: 400px;
        margin: 0 auto;
        background: var(--brand-dark);
        color: var(--brand-lime);
        padding: var(--spacing-md);
        border-radius: 0; 
    }

    .kiosk-screen {
        background: var(--brand-lime);
        color: var(--brand-dark);
        padding: var(--spacing-md);
        text-align: center;
        min-height: 150px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        margin-bottom: var(--spacing-md);
        border-radius: 4px; 
    }

    .numpad {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1px;
        background: rgba(168, 196, 220, 0.2);
        border: 1px solid rgba(168, 196, 220, 0.2);
    }

    .num-btn {
        background: var(--brand-dark);
        color: var(--brand-accent);
        border: none;
        padding: var(--spacing-md);
        font-family: var(--font-sans);
        font-size: 1.5rem;
        cursor: pointer;
        transition: background 0.1s;
    }

    .num-btn:hover {
        background: #1a2f5a;
        color: var(--brand-white);
    }

</style>
</head>
<body vid="9">

